# Secrets - never commit these
backend/.env
backend/.env.*
!backend/.env.example
backend/firebase/serviceAccountKey.json
**/serviceAccountKey.json
**/*.keystore
**/*.jks
key.properties

# Python bytecode
**/__pycache__/
*.pyc

# Firebase Data Connect — generated files (regenerated by the tooling)
dataconnect/.dataconnect/
dataconnect-generated/
**/dataconnect_generated/

# Firebase CLI logs & cache (emulator debug logs can contain connection strings)
.firebase/
*-debug.log

# Android / Kotlin build cache
**/.kotlin/

# OS cruft
.DS_Store
Thumbs.db