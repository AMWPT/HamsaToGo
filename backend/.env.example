# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed.

# --- Firebase ---
# Download your service account JSON from:
# Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_CREDENTIALS_PATH=firebase/serviceAccountKey.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# --- Staff ---
# Staff login via phone OTP. Comma-separated whitelist of authorized
# numbers in E.164 format. Each staff member logs in with their own phone.
STAFF_PHONES=+9665XXXXXXXX,+9665YYYYYYYY

# --- Firebase Web API Key ---
FIREBASE_WEB_API_KEY=your-web-api-key

# --- PostgreSQL ---
# Format: postgresql://username:password@host:port/dbname
# Leave empty to run with Firestore only (PostgreSQL is optional)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/hamsa

# --- Moyasar Payments ---
# Secret key from the Moyasar dashboard — never share or commit this.
# Leave empty during development to skip payment verification (logs a warning).
MOYASAR_SECRET_KEY=sk_test_your_secret_key

# --- App ---
APP_NAME=Hamsa To Go
DEBUG=True