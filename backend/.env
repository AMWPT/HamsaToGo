# ─── Firebase ───────────────────────────────────────────────
# Download your service account JSON from:
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH=firebase/serviceAccountKey.json

# Your Firebase project ID (found in Project Settings)
FIREBASE_PROJECT_ID=hamsacafe-1

# ─── Admin ──────────────────────────────────────────────────
# The fixed admin account credentials (single device login)
ADMIN_EMAIL=admin@hamsa.com
ADMIN_PASSWORD=staff123

# ─── Firebase Web API Key (for password-based login) ────────
# Found in Firebase Console → Project Settings → General → Your apps → apiKey
FIREBASE_WEB_API_KEY=AIzaSyDVguebQDElHrKLEn9uHM1maBakq4olXHQ

# ─── App ────────────────────────────────────────────────────
APP_NAME=Hamsa To Go
DEBUG=True
